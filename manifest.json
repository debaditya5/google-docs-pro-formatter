{
  "manifest_version": 3,
  "name": "Google Docs Pro Formatter",
  "version": "1.0",
  "description": "Single-key shortcuts and auto-resize image paste for Google Docs (Mac)",
  "permissions": ["storage", "clipboardWrite", "clipboardRead"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
